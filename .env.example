# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Square Payment Processing
# Get these from https://developer.squareup.com → your app → Credentials
#
# For sandbox testing:
#   VITE_SQUARE_APP_ID     = sandbox-sq0idb-...
#   VITE_SQUARE_LOCATION_ID = your sandbox location ID
#   VITE_SQUARE_ENVIRONMENT = sandbox
#
# For production:
#   VITE_SQUARE_APP_ID     = sq0idp-...   (no "sandbox-" prefix)
#   VITE_SQUARE_LOCATION_ID = your production location ID
#   VITE_SQUARE_ENVIRONMENT = production
#
# Edge function secrets (set via Supabase CLI):
#   supabase.exe secrets set SQUARE_ACCESS_TOKEN=... SQUARE_LOCATION_ID=... SQUARE_ENVIRONMENT=sandbox --project-ref kiayjlepwmdacojhpisq
VITE_SQUARE_APP_ID=
VITE_SQUARE_LOCATION_ID=
VITE_SQUARE_ENVIRONMENT=sandbox
